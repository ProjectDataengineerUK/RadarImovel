# Copie para .env e preencha os valores reais
# Nunca commite o .env no git

# Banco de dados (Cloud SQL via pg8000 ou local PostgreSQL)
DATABASE_URL=postgresql+pg8000://radar_app:senha@localhost/radar_imovel

# GCP
PUBSUB_PROJECT_ID=seu-projeto-gcp
GCS_BUCKET_RAW=radar-raw-seu-projeto-gcp

# Telegram
TELEGRAM_BOT_TOKEN=seu-token-aqui

# Firebase (JSON completo da service account — em uma linha)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Redis (para tokens temporários de conexão Telegram)
REDIS_URL=redis://localhost:6379

# Configurações opcionais
CAIXA_REQUEST_DELAY_MS=1000
CAIXA_MAX_RETRIES=3
ALERT_MAX_RETRIES=3
SCORE_DISCOUNT_MAX_POINTS=60
SCORE_OCCUPANCY_BONUS=40
TELEGRAM_TOKEN_TTL_SECONDS=900
API_CORS_ORIGINS=http://localhost:3000,https://radarimovel.com.br

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc wget \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir .[job]

# Playwright chromium (fallback — baixado sob demanda, não pré-instalado para manter imagem menor)
# RUN playwright install chromium --with-deps

COPY app/ app/
COPY jobs/ jobs/

ENV PYTHONUNBUFFERED=1

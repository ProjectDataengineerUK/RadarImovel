FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc wget \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir ".[job]"

# Playwright + Chromium para bypass do Radware Bot Manager no portal Caixa
RUN playwright install chromium --with-deps

COPY app/ app/
COPY jobs/ jobs/
COPY migrations/ migrations/
COPY alembic.ini .

ENV PYTHONUNBUFFERED=1

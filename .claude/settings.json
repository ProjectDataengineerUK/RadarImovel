{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/mempalace_setup.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v mempalace > /dev/null 2>&1 && bash \".claude/hooks/mempalace_save.sh\" || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v mempalace > /dev/null 2>&1 && bash \".claude/hooks/mempalace_precompact.sh\" || true"
          }
        ]
      }
    ]
  }
}